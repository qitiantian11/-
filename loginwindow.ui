  <property name="windowTitle">
   <string>图书馆管理系统 - 登录</string>
  </property>

  <property name="styleSheet">
   <string notr="true">
QWidget#LoginWindow {
    background-color: #EEF3F8;
    font-family: "Microsoft YaHei";
}

/* 左侧蓝色区域 */
QFrame#leftPanel {
    background: qlineargradient(
        x1:0,
        y1:0,
        x2:1,
        y2:1,
        stop:0 #355C7D,
        stop:0.55 #4F7CAC,
        stop:1 #6C8EBF
    );

    border-top-left-radius: 14px;
    border-bottom-left-radius: 14px;
}

/* 右侧登录卡片 */
QFrame#loginCard {
    background-color: white;
    border: 1px solid #DCE4EC;
    border-radius: 16px;
}

/* 左侧系统名称 */
QLabel#systemTitle {
    color: white;
    font-size: 30px;
    font-weight: bold;
}

/* 左侧英文名称 */
QLabel#systemSubtitle {
    color: #E8F0F7;
    font-size: 14px;
    letter-spacing: 1px;
}

/* 左侧介绍标题 */
QLabel#introTitle {
    color: white;
    font-size: 18px;
    font-weight: bold;
}

/* 左侧介绍内容 */
QLabel#introText {
    color: #EFF5FA;
    font-size: 14px;
    line-height: 1.8;
}

/* 左侧底部文字 */
QLabel#projectLabel {
    color: #DCE9F3;
    font-size: 12px;
}

/* 登录标题 */
QLabel#loginTitle {
    color: #2F4054;
    font-size: 27px;
    font-weight: bold;
}

/* 登录说明 */
QLabel#loginHint {
    color: #8A96A3;
    font-size: 13px;
}

/* 普通文字 */
QLabel {
    color: #46525F;
    font-size: 14px;
}

/* 输入框 */
QLineEdit {
    background-color: #F7F9FB;
    border: 1px solid #CFD8E3;
    border-radius: 8px;
    padding: 10px 12px;
    min-height: 24px;
    color: #273444;
    font-size: 14px;
}

QLineEdit:hover {
    border: 1px solid #9FB3C8;
}

QLineEdit:focus {
    background-color: white;
    border: 2px solid #5B8DEF;
}

/* 登录按钮 */
QPushButton#loginButton {
    background-color: #4F7CAC;
    color: white;
    border: none;
    border-radius: 8px;
    padding: 11px;
    font-size: 15px;
    font-weight: bold;
}

QPushButton#loginButton:hover {
    background-color: #416F9E;
}

QPushButton#loginButton:pressed {
    background-color: #355C7D;
}

/* 注册按钮 */
QPushButton#registerButton {
    background-color: white;
    color: #4F7CAC;
    border: 1px solid #4F7CAC;
    border-radius: 8px;
    padding: 10px;
    font-size: 15px;
    font-weight: bold;
}

QPushButton#registerButton:hover {
    background-color: #EDF4FB;
}

QPushButton#registerButton:pressed {
    background-color: #DFEAF4;
}

/* 右侧下方提示文字 */
QLabel#bottomHintLabel {
    color: #98A3AE;
    font-size: 12px;
}
   </string>
  </property>

