<ui version="4.0">
 <class>RegisterDialog</class>
 <widget class="QDialog" name="RegisterDialog">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>600</width>
    <height>620</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>读者注册</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
QDialog#RegisterDialog {
    background-color: #eef3f8;
    font-family: "Microsoft YaHei";
}

QFrame#registerCard {
    background-color: white;
    border: 1px solid #d9e2ea;
    border-radius: 16px;
}

QLabel#titleLabel {
    color: #33475b;
    font-size: 26px;
    font-weight: bold;
}

QLabel#subtitleLabel {
    color: #8793a0;
    font-size: 13px;
}

QLabel {
    color: #4b5967;
    font-size: 14px;
}

QLineEdit {
    background-color: #f7f9fb;
    border: 1px solid #cfd8e3;
    border-radius: 8px;
    padding: 10px 12px;
    min-height: 23px;
    color: #273444;
}

QLineEdit:focus {
    background-color: white;
    border: 2px solid #5b8def;
}

QPushButton#registerButton {
    background-color: #4f7cac;
    color: white;
    border: none;
    border-radius: 8px;
    padding: 11px 22px;
    font-size: 15px;
    font-weight: bold;
}

QPushButton#registerButton:hover {
    background-color: #416f9e;
}

QPushButton#cancelButton {
    background-color: #f4f6f8;
    color: #54616e;
    border: 1px solid #cfd8e3;
    border-radius: 8px;
    padding: 10px 22px;
    font-size: 15px;
}

QPushButton#cancelButton:hover {
    background-color: #e8edf2;
}
   </string>
  </property>

  <layout class="QVBoxLayout" name="mainLayout">
